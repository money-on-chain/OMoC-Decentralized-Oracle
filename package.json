{
    "name": "@moneyonchain/oracles",
    "version": "3.0.6",
    "description": "Money On Chain Oracles and Beyond Oracle smart contracts",
    "type": "module",
    "scripts": {
        "hh": "hardhat",
        "compile": "hardhat compile",
        "clean": "hardhat clean",
        "build": "pnpm clean && pnpm compile",
        "debug": "node inspect ./node_modules/hardhat/dist/src/cli.js test mocha",
        "test": "hardhat test mocha"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/money-on-chain/OMoC-Decentralized-Oracle.git"
    },
    "author": "",
    "license": "ISC",
    "prettier": {
        "tabWidth": 4,
        "printWidth": 100,
        "singleQuote": true,
        "trailingComma": "all",
        "semi": true,
        "overrides": [
            {
                "files": "*.sol",
                "options": {
                    "singleQuote": false
                }
            }
        ]
    },
    "eslintConfig": {
        "env": {
            "commonjs": true,
            "es2020": true,
            "node": true,
            "mocha": true,
            "truffle/globals": true
        },
        "plugins": ["truffle"],
        "extends": ["standard", "prettier"],
        "parserOptions": {
            "ecmaVersion": 11
        },
        "rules": {}
    },
    "bugs": {
        "url": "https://github.com/money-on-chain/OMoC-Decentralized-Oracle/issues"
    },
    "homepage": "https://github.com/money-on-chain/OMoC-Decentralized-Oracle#readme",
    "devDependencies": {
        "@moc/moc-main": "git+ssh://git@github.com/money-on-chain/main-sc-protocol-v2.git#v3.0.0",
        "@moc/periphery": "link:/work/moc/MoC-Periphery",
        "@nomicfoundation/hardhat-mocha": "^3.0.21",
        "@nomicfoundation/hardhat-network-helpers": "^3.0.10",
        "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
        "@openzeppelin/contracts": "4.9.3",
        "@openzeppelin/contracts-ethereum-package": "3.0.0",
        "@openzeppelin/contracts-upgradeable": "4.9.3",
        "@openzeppelin/upgrades": "2.8.0",
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^26.0.1",
        "chai": "^6.2.2",
        "hardhat": "3.9.0",
        "mocha": "^11",
        "solc": "0.6.12",
        "ts-test-helpers": "link:/work/moc/ts-test-helpers",
        "typechain": "^8.3.2",
        "typescript": "6.0.3",
        "viem": "2.53.1"
    },
    "files": ["contracts"],
    "main": "index.js",
    "exports": {
        "./contracts/*": "./contracts/*",
        "./package.json": "./package.json"
    },
    "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8"
}
