{
    "name": "@moneyonchain/oracles",
    "version": "3.0.7",
    "description": "Money On Chain Oracles and Beyond Oracle smart contracts",
    "type": "module",
    "scripts": {
        "hh": "hardhat",
        "compile": "hardhat compile",
        "clean": "hardhat clean",
        "build": "pnpm clean && pnpm compile",
        "debug": "node --inspect ./scripts/debug-hardhat.mjs test mocha",
        "format": "pnpm exec prettier ./test/* --write",
        "format:check": "pnpm exec prettier ./test/* --check",
        "lint": "pnpm exec eslint . --max-warnings 0",
        "lint:fix": "pnpm exec eslint . --fix --max-warnings 0",
        "precommit": "pnpm lint-staged && pnpm format:check",
        "prepare": "husky",
        "test": "hardhat test mocha"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/money-on-chain/OMoC-Decentralized-Oracle.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/money-on-chain/OMoC-Decentralized-Oracle/issues"
    },
    "homepage": "https://github.com/money-on-chain/OMoC-Decentralized-Oracle#readme",
    "dependencies": {
        "@moc/moc-main": "git+ssh://git@github.com/money-on-chain/main-sc-protocol-v2.git#v3.0.0",
        "@moc/periphery": "git+ssh://git@github.com/money-on-chain/MoC-Periphery#v3.0.4",
        "@openzeppelin/contracts": "4.9.3",
        "@openzeppelin/contracts-ethereum-package": "3.0.0",
        "@openzeppelin/contracts-upgradeable": "4.9.3",
        "@openzeppelin/upgrades": "2.8.0"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-mocha": "^3.0.21",
        "@nomicfoundation/hardhat-network-helpers": "^3.0.10",
        "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
        "@eslint/js": "^9.0.0",
        "@types/chai": "^5.2.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^26.0.1",
        "chai": "^6.2.2",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.0.0",
        "globals": "^16.0.0",
        "hardhat": "3.9.0",
        "husky": "^9.0.0",
        "lint-staged": "^16.0.0",
        "mocha": "^11",
        "prettier": "^3.0.0",
        "prettier-plugin-solidity": "^1.4.3",
        "solc": "0.6.12",
        "ts-test-helpers": "git+ssh://git@github.com/money-on-chain/ts-test-helpers#v0.1.0",
        "typescript": "6.0.3",
        "typescript-eslint": "^8.0.0",
        "viem": "2.53.1"
    },
    "files": [
        "contracts"
    ],
    "main": "index.js",
    "exports": {
        "./contracts/*": "./contracts/*",
        "./package.json": "./package.json"
    },
    "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8",
    "lint-staged": {
        "*.{js,ts}": [
            "pnpm exec eslint --fix --max-warnings 0 --no-warn-ignored"
        ],
        "*.{json,md,yml,yaml}": [
            "pnpm exec prettier --write"
        ]
    }
}
