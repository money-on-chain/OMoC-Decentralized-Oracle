{
    "compilerOptions": {
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["es2022"],
        "module": "NodeNext",
        "target": "es2022",
        "moduleResolution": "NodeNext",
        "noImplicitAny": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "allowImportingTsExtensions": false,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "types": ["hardhat", "node", "mocha", "chai"]
    },
    "include": [
        "artifacts/**/*.d.ts",
        "hardhat.config.ts",
        "scripts/**/*.ts",
        "test/hardhat/**/*.ts"
    ]
}
